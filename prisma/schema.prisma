// ============================================================
// AI Court — Prisma Schema
// مطابق لتصميم قاعدة البيانات في وثيقة GDD (القسم 8) + تحديثات
// نمطي اللعب (القسم play_mode) وعدم افتراض ذنب المتهم (case_pattern_type)
// ============================================================
 
generator client {
  provider = "prisma-client-js"
 binaryTargets = ["native","linux-arm64-openssl-1.1.x","debian-openssl-1.1.x","debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------- المستخدمون --------------------
model User {
  id           String   @id @default(uuid())
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  isGuest      Boolean  @default(true) @map("is_guest")
  totalPoints  Int      @default(0) @map("total_points")
  createdAt    DateTime @default(now()) @map("created_at")

  hostedRooms  Room[]        @relation("HostedRooms")
  roomPlayers  RoomPlayer[]

  @@map("users")
}

enum PlayMode {
  single_device
  multiplayer
}


enum RoomStatus {
  lobby
  generating
  reading
  trial
  verdict
  reveal
  ended

  @@map("room_status")
}

// -------------------- الغرف --------------------
model Room {
  id                    String     @id @default(uuid())
  code                  String     @unique @db.VarChar(6)
  hostUserId            String
  host                  User       @relation("HostedRooms", fields: [hostUserId], references: [id])
  status                RoomStatus @default(lobby)
  playMode              PlayMode   @map("play_mode")
  minPlayers            Int        @default(5) @map("min_players") // 3 في single_device
  maxPlayers            Int        @default(20) @map("max_players")
  inviteLink            String?    @map("invite_link") // multiplayer فقط
  qrCodeUrl             String?    @map("qr_code_url") // multiplayer فقط
  trialDurationSeconds  Int        @default(1200) @map("trial_duration_seconds")
  trialStartedAt        DateTime?  @map("trial_started_at")
  createdAt             DateTime   @default(now())

  players    RoomPlayer[]
  cases      Case[]
  trialEvents TrialEvent[]
  verdicts   Verdict[]
  roundScores RoundScore[]

  @@map("rooms")
}

// -------------------- القضايا (الحقيقة الكاملة - لا تُرسل أبدًا قبل الكشف) --------------------
// -------------------- بنك القضايا الجاهزة (بلا أي توليد حي) --------------------
// كل صف هنا قضية كاملة مكتوبة ومُراجَعة يدويًا مسبقًا: نفس بنية الحقيقة الأساسية
// وملفات الشخصيات التي كانت تُولَّد سابقًا عبر AI، لكنها الآن ثابتة ومستوردة مرة واحدة
// عبر سكربت الاستيراد (انظر prisma/import-case-templates.ts). لا يوجد أي نداء API
// في مسار اللعب الفعلي؛ التكلفة والحدود التشغيلية معدومة بالكامل.
model CaseTemplate {
  id              String          @id @default(uuid())
  title           String
  crimeType       String          @map("crime_type")
  setting         String
  groundTruth     Json            @map("ground_truth") // نفس بنية GroundTruth (schemas.ts) بعد التحقق عبر Zod وقت الاستيراد
  dossiers        Json            // مصفوفة CaseDossier بنفس ترتيب characters في groundTruth
  casePatternType CasePatternType @map("case_pattern_type")
  isActive        Boolean         @default(true) @map("is_active") // لتعطيل قضية بها خطأ لاحقًا دون حذفها
  timesUsed       Int             @default(0) @map("times_used")
  createdAt       DateTime        @default(now())

  @@map("case_templates")
}

enum CasePatternType {
  defendant_guilty
  defendant_innocent
  defendant_partial
}

model Case {
  id                       String          @id @default(uuid())
  roomId                   String
  room                     Room            @relation(fields: [roomId], references: [id])
  title                    String
  crimeType                String          @map("crime_type")
  setting                  String
  groundTruth              Json            @map("ground_truth")
  timeline                 Json
  realCulpritCharacterId   String?         @map("real_culprit_character_id")
  defendantCharacterId     String?         @map("defendant_character_id")
  casePatternType          CasePatternType @map("case_pattern_type") // داخلي فقط، غير مرئي للاعبين
  correctVerdict           Json            @map("correct_verdict")
  sourceTemplateId         String?         @map("source_template_id") // أي قضية من البنك استُخدمت (لتتبع التكرار)
  createdAt                DateTime        @default(now())

  characters Character[]
  evidences  Evidence[]

  @@map("cases")
}

// -------------------- الشخصيات المولّدة لكل قضية --------------------
enum RoleType {
  judge
  prosecutor
  defense
  defendant
  witness_main
  secondary
}

enum MotiveCategory {
  financial
  professional
  legal
  business
  administrative_violation
  past_mistake
  non_romantic_personal_dispute
  conflicting_interest
}

model Character {
  id                     String          @id @default(uuid())
  caseId                 String
  case                   Case            @relation(fields: [caseId], references: [id])
  roleType               RoleType        @map("role_type")
  roleName               String          @map("role_name") // مثال: "خبير بصمات"
  priorityOrder          Int             @map("priority_order")
  dossier                Json            // الملف السري الكامل
  motiveCategory         MotiveCategory? @map("motive_category")
  isIntentionalConflict  Boolean         @default(false) @map("is_intentional_conflict")

  assignedPlayer RoomPlayer?

  @@map("characters")
}

// -------------------- لاعبو الغرفة --------------------
model RoomPlayer {
  id           String   @id @default(uuid())
  roomId       String
  room         Room     @relation(fields: [roomId], references: [id])
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  localName    String?  @map("local_name") // لوضع الهاتف الواحد بلا حساب
  characterId  String?  @unique @map("character_id")
  character    Character? @relation(fields: [characterId], references: [id])
  isReady      Boolean  @default(false) @map("is_ready")
  joinedAt     DateTime @default(now()) @map("joined_at")

  trialEvents  TrialEvent[]
  verdicts     Verdict[]
  roundScores  RoundScore[]

  @@map("room_players")
}

// -------------------- الأدلة القابلة للكشف --------------------
model Evidence {
  id                 String    @id @default(uuid())
  caseId             String
  case               Case      @relation(fields: [caseId], references: [id])
  ownerCharacterId   String    @map("owner_character_id")
  title              String
  description        String
  isRevealed         Boolean   @default(false) @map("is_revealed")
  revealedAt         DateTime? @map("revealed_at")
  isDecisive         Boolean   @default(false) @map("is_decisive")

  @@map("evidences")
}

// -------------------- سجل أحداث المحاكمة العلني --------------------
enum TrialEventType {
  statement
  evidence_reveal
  question
  objection
  system
}

model TrialEvent {
  id             String         @id @default(uuid())
  roomId         String
  room           Room           @relation(fields: [roomId], references: [id])
  actorPlayerId  String?        @map("actor_player_id")
  actor          RoomPlayer?    @relation(fields: [actorPlayerId], references: [id])
  eventType      TrialEventType @map("event_type")
  content        String
  metadata       Json?
  createdAt      DateTime       @default(now())

  @@map("trial_events")
}

// -------------------- الحكم --------------------
enum VerdictEnum {
  guilty
  not_guilty
}

model Verdict {
  id             String      @id @default(uuid())
  roomId         String
  room           Room        @relation(fields: [roomId], references: [id])
  judgePlayerId  String      @map("judge_player_id")
  judge          RoomPlayer  @relation(fields: [judgePlayerId], references: [id])
  verdict        VerdictEnum
  penalty        String?
  matchesTruth   Boolean     @map("matches_truth")
  createdAt      DateTime    @default(now())

  @@map("verdicts")
}

// -------------------- النقاط لكل جولة --------------------
model RoundScore {
  id         String     @id @default(uuid())
  roomId     String
  room       Room       @relation(fields: [roomId], references: [id])
  playerId   String     @map("player_id")
  player     RoomPlayer @relation(fields: [playerId], references: [id])
  points     Int
  reason     String
  createdAt  DateTime   @default(now())

  @@map("round_scores")
}
